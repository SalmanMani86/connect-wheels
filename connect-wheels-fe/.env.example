# =====================================================================
# Frontend env vars — only variables prefixed with VITE_ are exposed
# to the browser bundle.
#
# Local dev:  copy to .env.local
# Vercel:     paste these into the Vercel dashboard for "Production"
# =====================================================================

# REST API base URL (the API Gateway). Include the /api suffix.
# Local:       http://localhost:8080/api
# Production:  https://cw-api-gateway.onrender.com/api
VITE_API_URL=http://localhost:8080/api

# Socket.IO endpoint (NO /api suffix — socket.io connects at the root)
# Local:       http://localhost:8080
# Production:  https://cw-api-gateway.onrender.com
VITE_SOCKET_URL=http://localhost:8080
