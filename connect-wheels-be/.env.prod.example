# =====================================================================
# .env.prod.example — copy to .env.prod and fill in real values.
# .env.prod is gitignored and MUST NOT be committed.
#
# Used by:  docker compose -f docker-compose.prod.yml --env-file .env.prod up
# =====================================================================

# --- Postgres (Neon) -------------------------------------------------
# Get these from your Neon dashboard → "Connection Details"
DB_HOST=ep-xxxx.region.aws.neon.tech
DB_PORT=5432
DB_USERNAME=neondb_owner
DB_PASSWORD=your_neon_password_here
DB_DATABASE=neondb
# Optional: separate DB for garage-service (else it reuses DB_DATABASE)
# GARAGE_DB_DATABASE=connect_wheels_garage

# --- MongoDB (Atlas) -------------------------------------------------
# Atlas → Connect → Drivers → copy the URI; replace <password> with the real one
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/connect_wheels_chat?retryWrites=true&w=majority

# --- JWT (must be SAME across all services that verify) --------------
# Generate locally with:  openssl rand -hex 64
JWT_SECRET=replace_with_a_long_random_64_byte_hex_string

# --- Google OAuth ----------------------------------------------------
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:8080/api/auth/google/callback

# --- Frontend / CORS -------------------------------------------------
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173
FRONTEND_URL=http://localhost:5173
FRONTEND_VERIFY_EMAIL_URL=http://localhost:5173/verify-email
