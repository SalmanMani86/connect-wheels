# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=admin
DB_PASSWORD=your_password_here
DB_DATABASE=connect_wheels_chat

# Server Configuration
CHAT_SERVICE_PORT=3001

# JWT Configuration (should match auth-service)
JWT_SECRET=your-jwt-secret

# Auth Service Configuration
AUTH_SERVICE_HOST=localhost
AUTH_SERVICE_PORT=3000
AUTH_SERVICE_GRPC_PORT=50051

# Kafka Configuration
KAFKA_BROKER=localhost:9092
KAFKA_CLIENT_ID=chat-service
KAFKA_GROUP_ID=chat-service-group

# WebSocket Configuration
WEBSOCKET_CORS_ORIGIN=http://localhost:5173

# Redis Configuration (for chat caching)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# File Upload Configuration
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,pdf,doc,docx

# Logging
LOG_LEVEL=info
